# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Dashboard configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DEBUG=False

# Docker & Network
CRAWLER_NETWORK=crawler-net
PROXY_HOST_DIR=/povn/poscrapling/Redis_Server/workers/Proxy

# Job Configuration
RESULT_TTL=3600
JOB_TIMEOUT_DEFAULT=120
JOB_TIMEOUT_NEWARK=720
JOB_TIMEOUT_AMAZON_FR=300
JOB_TIMEOUT_MANOMANO=180
JOB_TIMEOUT_ORCHESTRA=180

# Container resources
CONTAINER_MEM_LIMIT=1g
CONTAINER_SHM_SIZE=2g

# Max concurrent jobs - Global limit (all domains combined)
MAX_CONCURRENT_TOTAL=10

# Max concurrent jobs per domain (number of parallel containers)
MAX_CONCURRENT_FNAC=3
MAX_CONCURRENT_AMAZON_FR=3
MAX_CONCURRENT_NEWARK=3
MAX_CONCURRENT_MANOMANO=3
MAX_CONCURRENT_ORCHESTRA=3

